import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import LabelEncoder
# Load Netflix dataset (ensure CSV is in your working directory)
df = pd.read_csv("netflix_titles.csv")
print("✅ Dataset Loaded. Shape:", df.shape)
# Check for missing values
print("\n🔍 Missing Values:\n", df.isnull().sum())

# Check for duplicates
print("\n🔍 Duplicate Rows:", df.duplicated().sum())

# Check data types
print("\n🔍 Data Types:\n", df.dtypes)

# Display first few rows
df.head()
# Remove duplicate rows
df.drop_duplicates(inplace=True)

# Fill missing values for 'director' and 'cast' with 'Unknown'
df['director'] = df['director'].fillna("Unknown")
df['cast'] = df['cast'].fillna("Unknown")

# Drop rows where 'country' or 'date_added' is missing
df.dropna(subset=['country', 'date_added'], inplace=True)

# Convert 'date_added' to datetime safely
df['date_added'] = pd.to_datetime(df['date_added'].astype(str).str.strip(), errors='coerce')

# Fill missing 'duration' with default value
df['duration'] = df['duration'].fillna("0 min")

# Extract numeric value and unit from 'duration'
df['duration_int'] = df['duration'].str.extract('(\d+)').astype(float)
df['duration_type'] = df['duration'].str.extract('([a-zA-Z]+)')
# Normalize duration using NumPy
df['duration_norm'] = np.where(
    df['duration_int'].notnull(),
    (df['duration_int'] - np.nanmean(df['duration_int'])) / np.nanstd(df['duration_int']),
    0
)
# Filter only Movies
movies_df = df[df['type'] == 'Movie']

# Top 10 countries by content count
top_countries = df['country'].value_counts().head(10)
print("\n🌍 Top 10 Countries:\n", top_countries)

# Convert release_year to numeric and group by year
df['release_year'] = pd.to_numeric(df['release_year'], errors='coerce')
yearly_counts = df.groupby('release_year')['title'].count().sort_index()

# Plot yearly content production
plt.figure(figsize=(12, 5))
sns.lineplot(x=yearly_counts.index, y=yearly_counts.values)
plt.title("Netflix Content Releases by Year")
plt.xlabel("Year")
plt.ylabel("Number of Titles")
plt.grid(True)
plt.show()
# Show descriptive statistics
print("\n📊 Summary Statistics:\n")
print(df.describe(include='all'))
plt.figure(figsize=(12, 6))
sns.heatmap(df.isnull(), cbar=False, cmap='viridis')
plt.title("Heatmap of Missing Values")
plt.show()
plt.figure(figsize=(10, 6))
sns.heatmap(df.select_dtypes(include=[np.number]).corr(), annot=True, cmap='coolwarm')
plt.title("Correlation Matrix of Numeric Features")
plt.show()
# Encode 'type' and 'rating' for ML
le = LabelEncoder()
df['type_encoded'] = le.fit_transform(df['type'])
df['rating_encoded'] = le.fit_transform(df['rating'].astype(str))

# Show new encoded columns
df[['type', 'type_encoded', 'rating', 'rating_encoded']].head()
